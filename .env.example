# ============================================================================
# Wonder Crayon — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your real values.
# These are injected at build time via --dart-define flags.
#
# Local run example:
#   flutter run -d chrome \
#     --dart-define=POLLINATIONS_KEY=pk_your_key_here \
#     --dart-define=HF_TOKEN=hf_your_token_here
#
# For GitHub Actions CI/CD, add these as Repository Secrets:
#   Settings → Secrets and variables → Actions → New repository secret
# ============================================================================

# Pollinations.ai API key (get one at https://pollinations.ai)
POLLINATIONS_KEY=pk_your_key_here

# HuggingFace Inference API token (https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

