// ============================================================================
// Firebase Options — TEMPLATE FILE
// ============================================================================
// This file is a safe-to-commit template. It does NOT contain real API keys.
//
// TO SET UP FIREBASE:
//
//   Option A — Automatic (recommended):
//     1. firebase login
//     2. flutterfire configure
//     This generates lib/firebase_options.dart automatically.
//
//   Option B — Manual:
//     1. Copy this file:  cp lib/firebase_options.dart.example lib/firebase_options.dart
//     2. Replace every YOUR_..._HERE with your real values from the Firebase Console.
//     3. See instructions below for where to find each value.
//
// ⚠️  NEVER commit the real lib/firebase_options.dart — it is in .gitignore
// ============================================================================

import 'package:firebase_core/firebase_core.dart' show FirebaseOptions;
import 'package:flutter/foundation.dart'
    show defaultTargetPlatform, kIsWeb, TargetPlatform;

class DefaultFirebaseOptions {
  static FirebaseOptions get currentPlatform {
    if (kIsWeb) {
      _assertConfigured(web, 'web');
      return web;
    }
    switch (defaultTargetPlatform) {
      case TargetPlatform.android:
        _assertConfigured(android, 'android');
        return android;
      case TargetPlatform.iOS:
        _assertConfigured(ios, 'ios');
        return ios;
      case TargetPlatform.macOS:
        throw UnsupportedError(
          'DefaultFirebaseOptions have not been configured for macOS.',
        );
      case TargetPlatform.windows:
        throw UnsupportedError(
          'DefaultFirebaseOptions have not been configured for Windows.',
        );
      case TargetPlatform.linux:
        throw UnsupportedError(
          'DefaultFirebaseOptions have not been configured for Linux.',
        );
      default:
        throw UnsupportedError(
          'DefaultFirebaseOptions are not supported for this platform.',
        );
    }
  }

  // ---------------------------------------------------------------------------
  // 🌐 WEB
  // Firebase Console → Project Settings → Your apps → Web app → Config
  // ---------------------------------------------------------------------------
  static const FirebaseOptions web = FirebaseOptions(
    apiKey:            'YOUR_WEB_API_KEY_HERE',
    appId:             'YOUR_WEB_APP_ID_HERE',
    messagingSenderId: 'YOUR_MESSAGING_SENDER_ID_HERE',
    projectId:         'YOUR_PROJECT_ID_HERE',
    storageBucket:     'YOUR_STORAGE_BUCKET_HERE',
    authDomain:        'YOUR_AUTH_DOMAIN_HERE',
  );

  // ---------------------------------------------------------------------------
  // 🤖 ANDROID
  // Download google-services.json from Firebase Console → Project Settings
  // ---------------------------------------------------------------------------
  static const FirebaseOptions android = FirebaseOptions(
    apiKey:            'YOUR_ANDROID_API_KEY_HERE',
    appId:             'YOUR_ANDROID_APP_ID_HERE',
    messagingSenderId: 'YOUR_MESSAGING_SENDER_ID_HERE',
    projectId:         'YOUR_PROJECT_ID_HERE',
    storageBucket:     'YOUR_STORAGE_BUCKET_HERE',
  );

  // ---------------------------------------------------------------------------
  // 🍎 iOS
  // Download GoogleService-Info.plist from Firebase Console → Project Settings
  // ---------------------------------------------------------------------------
  static const FirebaseOptions ios = FirebaseOptions(
    apiKey:            'YOUR_IOS_API_KEY_HERE',
    appId:             'YOUR_IOS_APP_ID_HERE',
    messagingSenderId: 'YOUR_MESSAGING_SENDER_ID_HERE',
    projectId:         'YOUR_PROJECT_ID_HERE',
    storageBucket:     'YOUR_STORAGE_BUCKET_HERE',
    iosBundleId:       'com.example.wonderCrayon',
  );

  // ---------------------------------------------------------------------------
  // Helper — catches unfilled placeholders at startup with a clear error
  // ---------------------------------------------------------------------------
  static void _assertConfigured(FirebaseOptions opts, String platform) {
    if (opts.apiKey.startsWith('YOUR_') || opts.projectId.startsWith('YOUR_')) {
      throw StateError(
        '\n\n'
        '══════════════════════════════════════════════════════════════\n'
        '  Firebase is NOT configured for platform: $platform\n'
        '  Run: flutterfire configure\n'
        '  Or copy lib/firebase_options.dart.example to\n'
        '  lib/firebase_options.dart and fill in your real values.\n'
        '══════════════════════════════════════════════════════════════\n',
      );
    }
  }
}

